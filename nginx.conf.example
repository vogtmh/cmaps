# CompanyMaps 9 - example nginx reverse-proxy configuration.
#
# The Go application listens on 127.0.0.1:8096 and serves EVERYTHING itself:
# the map UI, the REST API, the admin panel, static assets and native SAML SSO.
# There is no PHP-FPM and no SimpleSAMLphp anymore - nginx only terminates TLS
# and proxies all paths (including the legacy /simplesaml/... ACS endpoints,
# which the Go app keeps registered for SSO compatibility) to the app.
#
# Adjust server_name and the certificate paths for your environment.

upstream companymaps {
    server 127.0.0.1:8096;
    keepalive 16;
}

# Redirect plain HTTP to HTTPS.
server {
    listen 80;
    listen [::]:80;
    server_name maps.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name maps.example.com;

    ssl_certificate     /etc/ssl/certs/maps.example.com.crt;
    ssl_certificate_key /etc/ssl/private/maps.example.com.key;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    # Map uploads and avatar images can be large.
    client_max_body_size 64m;

    location / {
        proxy_pass         http://companymaps;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   Connection        "";
        proxy_read_timeout 60s;
    }
}
